# .dockerignore

# Dependencies
node_modules

# Next.js build output
.next

# Optional: Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Optional: Environment variables (should be passed at runtime)
.env*
!.env.example

# Optional: OS generated files
.DS_Store
Thumbs.db

# Optional: IDE specific files
.vscode/
.idea/

# Optional: Test files (if not needed in production image)
# coverage/
# *.test.ts
# *.spec.ts
